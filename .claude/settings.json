{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(node scripts/*)",
      "Bash(bash scripts/*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(npx wrangler*)",
      "Bash(ls*)",
      "Bash(cat config.json)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  }
}
